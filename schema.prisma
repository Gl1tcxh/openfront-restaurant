  user       User?    @relation("Address_user", fields: [userId], references: [id])
  userId     String?  @map("user")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([userId])
}

model OrderItem {
  id                  String             @id @default(cuid())
  quantity            Int                @default(1)
  price               Int
